"""


def set_doc_font(run, east_asia: str = "SimSun", ascii_font: str = "Times New Roman", size: int = 12, bold: bool = False) -> None:
    run.font.size = Pt(size)
    run.font.bold = bold
    run.font.name = ascii_font
    run._element.rPr.rFonts.set(qn("w:eastAsia"), east_asia)


def add_paragraph(document: Document, text: str, *, bold: bool = False, center: bool = False, size: int = 12) -> None:
    p = document.add_paragraph()
    if center:
        p.alignment = WD_ALIGN_PARAGRAPH.CENTER
    p.paragraph_format.first_line_indent = Cm(0.85) if not center else Cm(0)
    p.paragraph_format.space_after = Pt(0)
    run = p.add_run(text)
    set_doc_font(run, size=size, bold=bold)


def add_heading(document: Document, text: str, level: int) -> None:
    p = document.add_paragraph()
    if level == 1:
        p.alignment = WD_ALIGN_PARAGRAPH.CENTER
        run = p.add_run(text)
        set_doc_font(run, east_asia="SimHei", size=15, bold=False)
    elif level == 2:
        run = p.add_run(text)
        set_doc_font(run, east_asia="SimHei", size=14, bold=False)
    else:
        run = p.add_run(text)
        set_doc_font(run, east_asia="SimHei", size=12, bold=False)
    p.paragraph_format.first_line_indent = Cm(0)
    p.paragraph_format.space_after = Pt(0)


def add_table(document: Document, title: str, headers: list[str], rows: list[list[str]]) -> None:
    add_paragraph(document, title, center=True)
    table = document.add_table(rows=1, cols=len(headers))
    table.alignment = WD_TABLE_ALIGNMENT.CENTER
    table.style = "Table Grid"
    hdr_cells = table.rows[0].cells
    for idx, header in enumerate(headers):
        hdr_cells[idx].text = header
    for row in rows:
        cells = table.add_row().cells
        for idx, value in enumerate(row):
            cells[idx].text = value
    for row in table.rows:
        for cell in row.cells:
            for p in cell.paragraphs:
                p.alignment = WD_ALIGN_PARAGRAPH.CENTER
                for run in p.runs:
                    set_doc_font(run, size=10)


def build_docx(data: dict[str, object]) -> None:
    document = Document()
    section = document.sections[0]
    section.top_margin = Cm(3.0)
    section.bottom_margin = Cm(3.0)
    section.left_margin = Cm(3.0)
    section.right_margin = Cm(3.0)

    p = document.add_paragraph()
    p.alignment = WD_ALIGN_PARAGRAPH.CENTER
    run = p.add_run(TITLE_ZH)
    set_doc_font(run, east_asia="SimHei", size=16, bold=True)

    add_paragraph(document, "中国石油大学（北京）本科毕业设计（论文）初稿", center=True, size=12)
    add_paragraph(document, "学生：余冰雁    学号：2022012085    专业：信息管理与信息系统", center=True, size=12)
    add_paragraph(document, "")

    add_heading(document, "摘要", 1)
    add_paragraph(document, build_abstract_zh(data))
    add_paragraph(document, "关键词：高质量期刊文献；石油领域；研究机构；学术影响力；主题演化")

    add_heading(document, "ABSTRACT", 1)
    add_paragraph(document, TITLE_EN, center=True, size=12)
    add_paragraph(document, build_abstract_en(data))
    add_paragraph(document, "Key Words: high-quality journal literature; petroleum research institutions; academic influence; TOPSIS; topic evolution")

    markdown = build_markdown(data)
    body_sections = [line for line in markdown.splitlines() if line.strip()]
    for line in body_sections:
        if line.startswith("# "):
            continue
        if line.startswith("## "):
            add_heading(document, line[3:], 1)
        elif line.startswith("### "):
            add_heading(document, line[4:], 2)
        elif line.startswith("| "):
            continue
        elif line.startswith("**关键词：") or line.startswith("**Key Words:"):
            continue
        else:
            add_paragraph(document, line)

    weights_rows = [
        [row["label_zh"], row["dimension_zh"], f"{float(row['combined_weight']):.6f}"]
        for row in data["weights"]
    ]
    add_table(document, "表3-1 组合赋权结果", ["指标", "维度", "组合权重"], weights_rows)

    top10_rows = [
        [
            row["TOPSIS综合排名"],
            row["标准化机构名称"],
            row["主属国家/地区"],
            row["TOPSIS综合得分"],
            row["主导优势维度"],
        ]
        for row in data["top20"][:10]
    ]
    add_table(document, "表3-2 TOPSIS 综合排名前十机构", ["排名", "机构", "国家/地区", "综合得分", "主导优势维度"], top10_rows)

    model_rows = [
        [
            row["阶段"],
            row["进入建模文献数"],
            str(data["selected_k"][row["阶段"]]["k"]),
            data["selected_k"][row["阶段"]]["perplexity"],
            data["selected_k"][row["阶段"]]["coherence"],
        ]
        for row in data["preprocess_rows"]
    ]
    add_table(document, "表4-1 三阶段主题模型选择结果", ["阶段", "建模文献数", "选定主题数", "困惑度", "一致性得分"], model_rows)

    for figure_name in [
        "topic_intensity_evolution_curve_dual_key_2011_2025.png",
        "topic_distribution_heatmap_by_institution_type_dual_key_2011_2025.png",
    ]:
        figure_path = TOPIC_DIR / figure_name
        if figure_path.exists():
            document.add_picture(str(figure_path), width=Cm(15.5))
            caption = "图 " + figure_name.replace("_dual_key_2011_2025.png", "").replace("_", " ")
            add_paragraph(document, caption, center=True, size=11)

    document.save(DOCX_OUTPUT)


def build_qa(data: dict[str, object]) -> str:
    type_counts: Counter[str] = data["type_counts"]
    return f"""# 论文交付 QA 清单（2026-04-24）

## 自动通过项
- 正式语料口径已统一为 `2011-2025 dual_key_dedup`。
- 机构评价链已重跑并生成最新的频次表、Top100、指标表、TOPSIS 得分表和机构类型表。
- 主题演化链核心结果文件已齐全，当前目录包含主题强度、文献主题归属、相似度连接、演化路径、机构类型分布和机构层级分布。
- `institution_type_review_top100_dual_key_2011_2025.csv` 与机构类型主题分布表中的企业类标签已统一为“企业研发中心”。
- 机构画像表中的 4 条括注前置别名已归并到正式标准名，当前有效机构画像数量为 {len(data['profile_rows'])}。
- 中文交付表已刷新，核心中文 CSV 可按 `gb18030` 打开。

## 需要人工复核项
- 参考文献目前为初稿清单，需按正文实际引文统一补足并核校到不少于 15 篇，其中外文不少于 4 篇。
- 英文摘要仍建议做语法和术语润色，以贴合最终提交版表达。
- 机构类型中仍有 {type_counts['其他']} 个“其他”机构未纳入正式类型比较，正式稿中应保留方法限制说明。
- 国际组织在有效机构过滤后未形成稳定样本，正式定稿时需保留“未单独展开比较”的限制说明。
- 若需完全贴合学校模板页眉页脚、标题间距和目录样式，可在本机 Word COM 环境中再运行 `format_word_doc_with_template.ps1` 做最终版式整理。

## 输出文件
- Markdown 草稿：`{MD_OUTPUT}`
- Word 初稿：`{DOCX_OUTPUT}`
- 本 QA 清单：`{QA_OUTPUT}`
"""


def main() -> None:
    MANUSCRIPT_DIR.mkdir(parents=True, exist_ok=True)
    QA_DIR.mkdir(parents=True, exist_ok=True)

    data = load_data()
    markdown = build_markdown(data)
    MD_OUTPUT.write_text(markdown, encoding="utf-8")
    build_docx(data)
    QA_OUTPUT.write_text(build_qa(data), encoding="utf-8")

    print(f"markdown_output={MD_OUTPUT}")
    print(f"docx_output={DOCX_OUTPUT}")
    print(f"qa_output={QA_OUTPUT}")


if __name__ == "__main__":
    main()
